{
  "productName": "LocaFetch",
  "version": "0.1.0",
  "identifier": "com.locafetch.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LocaFetch",
        "width": 680,
        "height": 68,
        "minWidth": 680,
        "maxWidth": 680,
        "resizable": false,
        "center": true,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
